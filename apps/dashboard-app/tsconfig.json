{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["bun"],
    "paths": {
      "@catalog": ["./src/catalog/catalog.ts"],
      "@/*": ["./src/renderer/*"]
    }
  },
  "include": ["src", "scripts"]
}
