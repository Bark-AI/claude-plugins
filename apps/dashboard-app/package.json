{
  "name": "@bark/dashboard-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun ./index.html",
    "build:renderer": "bun build --compile --target=browser --minify ./index.html --outdir dist/renderer",
    "build:catalog": "bun scripts/build-catalog.ts",
    "publish:renderer": "cp dist/renderer/index.html ../../plugins/bark-cowork/skills/design-dashboard/templates/dashboard.template.html",
    "publish:catalog": "bun scripts/publish-catalog.ts"
  },
  "dependencies": {
    "@json-render/core": "0.19.0",
    "@json-render/react": "0.19.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "streamdown": "2.5.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
